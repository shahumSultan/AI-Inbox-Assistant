# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@db:5432/inboxai

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-a-long-random-string
ENCRYPTION_KEY=change-me-in-production-32-bytes

# ── AI ────────────────────────────────────────────────────────────────────────
LLM_API_KEY=sk-ant-...
LLM_MODEL_ANALYSIS=claude-sonnet-4-6
LLM_MODEL_REPLY=claude-sonnet-4-6

# ── App ───────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Admin ─────────────────────────────────────────────────────────────────────
# Comma-separated list of emails that get admin access (no trial, no paywall)
ADMIN_EMAIL=you@yourdomain.com

# ── Google OAuth (Gmail) ──────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/ → APIs & Services → Credentials
# Enable the Gmail API, set redirect URI to: http://localhost:8000/api/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/oauth/google/callback

# ── Microsoft OAuth (Outlook / Hotmail) ───────────────────────────────────────
# Register app at https://portal.azure.com/ → App registrations
# Set redirect URI to: http://localhost:8000/api/oauth/microsoft/callback
# Use "common" for multi-tenant (any Microsoft account)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:8000/api/oauth/microsoft/callback
MICROSOFT_TENANT_ID=common

# ── Optional (billing / email) ────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# SENDGRID_API_KEY=SG....
